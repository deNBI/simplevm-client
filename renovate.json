{
  "extends": [
    "config:recommended",
  ],
  "packageRules": [
    {
      "matchUpdateTypes": [
        "major"
      ],
      "addLabels": [
        "major"
      ]
    },
    {
      "matchUpdateTypes": [
        "minor"
      ],
      "addLabels": [
        "minor"
      ]
    },
    {
      "matchUpdateTypes": [
        "patch"
      ],
      "addLabels": [
        "patch"
      ]
    },
    {
      "matchUpdateTypes": [
        "pin"
      ],
      "addLabels": [
        "pin"
      ]
    }
  ],
  "pre-commit": {
    "enabled": true
  },
  "baseBranches": [
    "dev"
  ],
  "reviewers": [
    "team:portal-dev"
  ],
  "labels": [
    "dependencies"
  ],
  "assignees": [
    "team:portal-dev"
  ],
  "vulnerabilityAlerts": {
    "labels": [
      "security"
    ]
  },
  "branchPrefix": "deps/",
  "bumpVersion": "minor",
  "commitBodyTable": true,
  "commitMessagePrefix": "feat(Dependencies):"
}
